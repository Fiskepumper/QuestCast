<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/global.css">
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/signup.css">
  <%- style %>
</head>
<body>
  <!-- Global Navbar -->
  <nav class="global-navbar">
    <div class="nav-container">
      <div class="nav-brand">
        <a href="/">
          <img src="/QC.png" alt="QuestCast Logo" class="brand-logo">
        </a>
      </div>
      <ul class="nav-menu">
        <% if (locals.currentUser) { %>
          <li style="display:flex;align-items:center;gap:10px;">
            <a href="/profile" class="nav-profile-btn">
              <% const av = currentUser.avatarChoice; %>
              <% if (av === 'Cosen') { %>
                <img src="/Cosen.png" alt="avatar" class="nav-avatar">
              <% } else if (av === 'Jeppe') { %>
                <img src="/Jeppe.png" alt="avatar" class="nav-avatar">
              <% } else if (currentUser.avatarUrl) { %>
                <img src="<%= currentUser.avatarUrl %>" alt="avatar" class="nav-avatar">
              <% } else { %>
                <span class="nav-avatar nav-avatar-initial"><%= (currentUser.displayName || currentUser.username || '?')[0].toUpperCase() %></span>
              <% } %>
              <span><%= currentUser.displayName || currentUser.username %></span>
            </a>
            <% if (currentUser.walletAddress) { %>
            <div class="nav-balance" id="nav-balance" title="Din QuestCast USDC-balanse">
              <img src="/usdc-pol.png" alt="USDC" style="width:16px;height:16px;border-radius:50%;vertical-align:middle;">
              <span id="nav-usdc-amount">–</span>
            </div>
            <script>
              (async () => {
                const addr = <%- JSON.stringify(currentUser.walletAddress) %>;
                async function fetchNavBalance() {
                  try {
                    const r = await fetch('/api/contract-balance?address=' + encodeURIComponent(addr));
                    const d = await r.json();
                    if (!d.error) document.getElementById('nav-usdc-amount').textContent = d.usdc + ' USDC';
                  } catch {}
                }
                fetchNavBalance();
                // Oppdater hvert 30s
                setInterval(fetchNavBalance, 30000);
                // Lytt på deposit-event fra profilsiden
                window.addEventListener('questcast:deposit', fetchNavBalance);
              })();
            </script>
            <% } %>
          </li>
        <% } else { %>
          <li><button class="nav-connect-btn" onclick="document.getElementById('signup-modal').classList.add('open')">Sign Up</button></li>
        <% } %>
      </ul>
    </div>
  </nav>

  <!-- Sign Up Modal -->
  <div class="modal-overlay" id="signup-modal" onclick="if(event.target===this)this.classList.remove('open')">
    <div class="modal-box">
      <button class="modal-close" onclick="document.getElementById('signup-modal').classList.remove('open')">&times;</button>

      <!-- View 1: OAuth-valg -->
      <div id="modal-view-main">
        <h2 class="modal-title">Join QuestCast</h2>
        <p class="modal-subtitle">Registrer deg for å delta i challenges</p>

        <% if (locals.authError === 'not-configured') { %>
          <div class="modal-error">⚠️ Denne innloggingsmetoden er ikke konfigurert ennå.</div>
        <% } else if (locals.authError) { %>
          <div class="modal-error">⚠️ Innlogging feilet. Prøv igjen eller bruk et annet alternativ.</div>
        <% } %>

        <div class="oauth-buttons">
          <a href="/auth/google" class="oauth-btn">
            <img src="/google.png" alt="Google" class="oauth-icon">
            <span>Fortsett med Google</span>
          </a>
          <a href="/auth/microsoft" class="oauth-btn">
            <img src="/microsoft.png" alt="Microsoft" class="oauth-icon">
            <span>Fortsett med Microsoft</span>
          </a>
          <button type="button" id="metamask-btn" class="oauth-btn metamask-btn">
            <img src="/MetaMaskLogo.png" alt="MetaMask" class="oauth-icon">
            <span>Fortsett med MetaMask</span>
          </button>
        </div>
      </div>

      <!-- View 2: MetaMask QR -->
      <div id="modal-view-metamask" style="display:none;">
        <button type="button" class="modal-back-btn" id="metamask-back-btn">&#8592; Tilbake</button>
        <h2 class="modal-title">MetaMask</h2>
        <p class="modal-subtitle">Skann med MetaMask-appen på telefonen</p>

        <div style="text-align:center;margin:16px 0;">
          <img id="metamask-qr-img" src="" alt="QR kode" style="border-radius:12px;border:2px solid #00ffcc;padding:8px;background:#fff;width:210px;height:210px;display:block;margin:0 auto;">
          <p style="color:#666;font-size:0.75rem;margin-top:8px;">Åpner QuestCast i MetaMask sin nettleser</p>
        </div>

        <div id="metamask-device-wrap">
          <div class="modal-divider"><span>eller</span></div>
          <button type="button" id="metamask-device-btn" class="oauth-btn metamask-btn">
            <img src="/MetaMaskLogo.png" alt="MetaMask" class="oauth-icon">
            <span>Continue with this device</span>
          </button>
        </div>
      </div>

      <script>
        function showMetaMaskView() {
          document.getElementById('modal-view-main').style.display = 'none';
          document.getElementById('modal-view-metamask').style.display = 'block';

          const host = window.location.hostname === 'localhost'
            ? 'questcast-gfejc6f4g0ddehbq.azurewebsites.net'
            : window.location.hostname;
          const url = 'https://metamask.app.link/dapp/' + host;
          const qrApi = 'https://api.qrserver.com/v1/create-qr-code/?size=210x210&margin=6&data=' + encodeURIComponent(url);
          document.getElementById('metamask-qr-img').src = qrApi;
        }

        document.getElementById('metamask-btn').addEventListener('click', showMetaMaskView);

        document.getElementById('metamask-back-btn').addEventListener('click', () => {
          document.getElementById('modal-view-metamask').style.display = 'none';
          document.getElementById('modal-view-main').style.display = 'block';
        });

        document.getElementById('metamask-device-btn').addEventListener('click', async () => {
          if (!window.ethereum) {
            alert('MetaMask-utvidelsen er ikke installert i denne nettleseren.');
            return;
          }
          try {
            const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
            const res = await fetch('/auth/metamask', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ address: accounts[0] }),
            });
            const data = await res.json();
            if (data.ok) window.location.href = '/profile?deposit=1';
            else alert('Noe gikk galt. Prøv igjen.');
          } catch (err) {
            alert('MetaMask-tilkobling avbrutt.');
          }
        });
      </script>
    </div>
  </div>

  <!-- Main Content -->
  <main class="main-content">
    <%- body %>
  </main>

  <!-- Global Footer -->
  <footer class="global-footer">
    <div class="footer-container">
      <div class="footer-section">
        <h4>QuestCast</h4>
        <p>Live Challenge Registration Platform</p>
      </div>
      <div class="footer-section">
        <h4>Links</h4>
        <ul>
          <li><a href="/">Challenges</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> QuestCast. All rights reserved.</p>
    </div>
  </footer>

  <% if (locals.authError) { %>
    <script>document.getElementById('signup-modal').classList.add('open');</script>
  <% } %>

  <% if (locals.registered) { %>
    <div id="reg-toast">✅ Velkommen til QuestCast!</div>
    <script>
      setTimeout(() => {
        const t = document.getElementById('reg-toast');
        if (t) t.classList.add('hide');
      }, 4000);
    </script>
  <% } %>
</body>
</html>
